{
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    },
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, max-age=0" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/tracking/:receipt", "destination": "/api/tracking?receipt=:receipt" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
